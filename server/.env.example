# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
# Local MongoDB: mongodb://localhost:27017/coinbase-clone
# MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/coinbase-clone
MONGODB_URI=mongodb://localhost:27017/coinbase-clone

# JWT Secret (Change this to a long random string in production!)
JWT_SECRET=your_jwt_secret_key_here_change_this_in_production

# Frontend Client URL (for CORS)
CLIENT_URL=http://localhost:5173
